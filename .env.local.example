# Copia este archivo a .env.local y completa con tus valores reales.
# .env.local nunca debe subirse a git (ya está en .gitignore por defecto en Next.js).

# URL pública de tu proyecto Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública "anon" — segura de exponer en el navegador porque las
# tablas están protegidas por RLS (ver supabase/sql/schema.sql).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clave secreta "service_role" — SOLO se usa en /src/pages/api/**.
# NUNCA la prefijes con NEXT_PUBLIC_, nunca la subas a git, nunca la
# expongas en el cliente: ignora RLS por completo.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Secreto simple para proteger /api/admin/generar-numeros. Usa un valor
# largo y aleatorio (ej. generado con `openssl rand -hex 32`).
ADMIN_SECRET_KEY=cambia-esto-por-un-valor-secreto-y-largo
